{
  "name": "cloud-clips",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build": "expo build",
    "lint": "eslint src/**/*.{ts,tsx}",
    "format": "prettier --write \"src/**/*.{ts,tsx,json}\"",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "maestro test",
    "type-check": "tsc --noEmit",
    "setup:env": "[ -f .env ] || cp .env.example .env",
    "env:check": "node -e \"require('fs').existsSync('.env') || (console.error('ERROR: .env file not found. Run: cp .env.example .env') || process.exit(1))\"",
    "predev": "npm run env:check",
    "clean": "rm -rf node_modules .expo dist",
    "postinstall": "npm run setup:env",
    "bundle:analyze": "react-native bundle --platform android --dev false --entry-file index.ts --bundle-output /tmp/cc-bundle.js --sourcemap-output /tmp/cc-bundle.map && npx source-map-explorer /tmp/cc-bundle.js /tmp/cc-bundle.map"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/netinfo": "^11.5.2",
    "@react-native-google-signin/google-signin": "^16.1.1",
    "@sentry/react-native": "~7.12.0",
    "@stripe/stripe-react-native": "~0.58.0",
    "@tanstack/query-async-storage-persister": "^5.90.22",
    "@tanstack/query-sync-storage-persister": "^5.90.22",
    "@tanstack/react-query": "^5.90.20",
    "@tanstack/react-query-persist-client": "^5.90.22",
    "axios": "^1.13.5",
    "convex": "^1.17.0",
    "date-fns": "^4.1.0",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-av": "^16.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "^17.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "^15.0.8",
    "expo-document-picker": "^14.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linking": "~8.0.11",
    "expo-local-authentication": "~17.0.8",
    "expo-localization": "~17.0.8",
    "expo-location": "^19.0.8",
    "expo-media-library": "^18.2.1",
    "expo-notifications": "~0.32.16",
    "expo-print": "^15.0.8",
    "expo-router": "~6.0.23",
    "expo-sharing": "^14.0.8",
    "expo-status-bar": "~3.0.9",
    "firebase": "^10.14.1",
    "i18next": "^25.8.4",
    "jotai": "^2.17.1",
    "nativewind": "^4.0.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.71.1",
    "react-i18next": "^16.5.4",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-image-picker": "^8.2.1",
    "react-native-maps": "^1.27.1",
    "react-native-mmkv": "^4.1.2",
    "react-native-nitro-modules": "0.33.2",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "^0.7.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.17",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "axios-mock-adapter": "^2.1.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^8.57.1",
    "eslint-config-expo": "^10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.17",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "tailwindcss": "^3.4.19",
    "typescript": "~5.9.2"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.{json,css}": [
      "prettier --write"
    ]
  },
  "private": true
}
