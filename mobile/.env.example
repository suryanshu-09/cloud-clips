# =============================================================================
# Cloud Clips Mobile App - Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your environment
# NEVER commit .env files with real credentials to version control
# 
# Setup Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Get your Convex URL from: https://dashboard.convex.dev
# 3. Get your Stripe publishable key from: https://dashboard.stripe.com/apikeys
# 4. Configure Google Sign-In at: https://console.cloud.google.com/apis/credentials
# =============================================================================

# =============================================================================
# CONVEX CONFIGURATION (Required)
# =============================================================================
# Your Convex deployment URL
# Development: Get from `npx convex dev` output or Convex dashboard
# Format: https://<your-deployment>.convex.cloud
EXPO_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# =============================================================================
# DEVELOPMENT MODE
# =============================================================================
# Set to 'true' to enable mock services, debug logging, and dev helpers
# Set to 'false' for production builds
EXPO_PUBLIC_DEV_MODE=true

# =============================================================================
# STRIPE PAYMENTS (Required for payments feature)
# =============================================================================
# Get your keys from: https://dashboard.stripe.com/apikeys
# Use test keys (pk_test_) for development, live keys (pk_live_) for production
# The backend uses the secret key to create payment intents
EXPO_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# =============================================================================
# GOOGLE SIGN-IN (Optional - for social authentication)
# =============================================================================
# Get from: https://console.cloud.google.com/apis/credentials
# Required for: Google Sign-In via Convex Auth
# 
# Web Client ID (for web and Android)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_web_client_id.apps.googleusercontent.com
# 
# iOS Client ID (for iOS only)
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=your_google_ios_client_id.apps.googleusercontent.com

# =============================================================================
# APPLE SIGN-IN (Optional - for iOS social authentication)
# =============================================================================
# Apple Sign-In is configured via app.json with iOS entitlements
# Bundle ID must match your Apple Developer account configuration
# See: https://developer.apple.com/documentation/sign_in_with_apple

# =============================================================================
# ERROR TRACKING (Optional - for production error monitoring)
# =============================================================================
# Get your DSN from: https://sentry.io/settings/projects/
EXPO_PUBLIC_SENTRY_DSN=your_sentry_dsn_here

# =============================================================================
# EAS (Expo Application Services) Configuration
# =============================================================================
# Get from: https://expo.dev/accounts/[account]/projects/[project]/settings
# Required for: OTA updates, build submissions, push notifications
EXPO_PUBLIC_EAS_PROJECT_ID=your_eas_project_id_here

# =============================================================================
# FEATURE FLAGS (Optional - for gradual feature rollouts)
# =============================================================================
# Enable/disable specific features during development
EXPO_PUBLIC_ENABLE_CHAT=true
EXPO_PUBLIC_ENABLE_PAYMENTS=true
EXPO_PUBLIC_ENABLE_PUSH_NOTIFICATIONS=true
EXPO_PUBLIC_ENABLE_PRODUCT_MARKETPLACE=true

# =============================================================================
# API RATE LIMITS & TIMEOUTS
# =============================================================================
# Request timeout in milliseconds
EXPO_PUBLIC_API_TIMEOUT=30000
# Geocoding debounce delay in milliseconds
EXPO_PUBLIC_GEOCODE_DEBOUNCE=300

# =============================================================================
# MAP CONFIGURATION
# =============================================================================
# OpenStreetMap tile server URL
# Default OSM: https://tile.openstreetmap.org/{z}/{x}/{y}.png
# Alternative (with User-Agent): https://tiles.wmflabs.org/osm/{z}/{x}/{y}.png
EXPO_PUBLIC_MAP_TILE_URL=https://tile.openstreetmap.org/{z}/{x}/{y}.png

# Default map location (New York City)
EXPO_PUBLIC_DEFAULT_MAP_LAT=40.7128
EXPO_PUBLIC_DEFAULT_MAP_LNG=-74.0060
EXPO_PUBLIC_DEFAULT_MAP_ZOOM=12
