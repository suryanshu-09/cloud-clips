{
  "expo": {
    "name": "Cloud Clips",
    "slug": "cloud-clips",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "cloudclips",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0ea5e9"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.cloudclips.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to find nearby barbers",
        "NSLocationAlwaysUsageDescription": "We need your location to find nearby barbers and provide location-based services",
        "NSCameraUsageDescription": "We need camera access to upload photos",
        "NSPhotoLibraryUsageDescription": "We need photo library access to upload images",
        "UIBackgroundModes": ["fetch", "remote-notification"],
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": ["cloudclips"]
          }
        ]
      },
      "associatedDomains": [
        "applinks:cloudclips.app",
        "applinks:www.cloudclips.app"
      ],
      "config": {
        "googleMapsApiKey": "YOUR_GOOGLE_MAPS_API_KEY"
      },
      "entitlements": {
        "com.apple.developer.associated-domains": [
          "applinks:cloudclips.app",
          "applinks:www.cloudclips.app"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0ea5e9"
      },
      "package": "com.cloudclips.app",
      "versionCode": 1,
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "POST_NOTIFICATIONS",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ],
      "softwareKeyboardLayoutMode": "resize",
      "predictiveBackGestureEnabled": false,
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_API_KEY"
        }
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "cloudclips.app",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "www.cloudclips.app",
              "pathPrefix": "/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        },
        {
          "action": "VIEW",
          "data": [
            {
              "scheme": "cloudclips"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Cloud Clips to use your location to find nearby barbers."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Cloud Clips to access your photos to upload profile pictures and portfolio images.",
          "cameraPermission": "Allow Cloud Clips to access your camera to take photos."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0ea5e9"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 34,
            "targetSdkVersion": 34,
            "buildToolsVersion": "34.0.0"
          },
          "ios": {
            "deploymentTarget": "15.1"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "your-project-id-here"
      }
    },
    "owner": "cloudclips",
    "updates": {
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/your-project-id-here"
    },
    "runtimeVersion": {
      "policy": "sdkVersion"
    }
  }
}
