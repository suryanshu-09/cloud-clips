# =============================================================================
# Cloud Clips Backend - Environment Configuration
# =============================================================================
# Copy this file to .env and update the values for your environment
# NEVER commit .env files with real credentials to version control
#
# Setup Instructions:
# 1. Copy this file: cp .env.example .env
# 2. Run `npx convex dev` to get your deployment URL
# 3. Configure OAuth providers in Convex dashboard
# 4. Add Stripe keys from https://dashboard.stripe.com/apikeys
# =============================================================================

# =============================================================================
# CONVEX DEPLOYMENT (Required)
# =============================================================================
# Your Convex deployment identifier
# Get this from: https://dashboard.convex.dev > Settings > Deployment
# Or run: npx convex dev (it will show the deployment URL)
CONVEX_DEPLOYMENT=your-deployment-name

# Convex deploy key (for CI/CD deployments)
# Get from: https://dashboard.convex.dev > Settings > Deploy Key
CONVEX_DEPLOY_KEY=your_deploy_key_here

# =============================================================================
# AUTHENTICATION - RESEND EMAIL (Required for email magic links)
# =============================================================================
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_resend_api_key_here

# From email address for sending magic links
# Must be a verified domain in Resend
AUTH_EMAIL_FROM=noreply@yourdomain.com

# =============================================================================
# AUTHENTICATION - GOOGLE OAUTH (Optional - for social login)
# =============================================================================
# Get from: https://console.cloud.google.com/apis/credentials
# Create OAuth 2.0 credentials and add authorized redirect URIs:
# - https://your-deployment.convex.site/api/auth/callback/google
AUTH_GOOGLE_ID=your_google_client_id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your_google_client_secret

# =============================================================================
# AUTHENTICATION - APPLE SIGN-IN (Optional - for iOS social login)
# =============================================================================
# Configure in Apple Developer portal: https://developer.apple.com/account/resources/
# Create Services ID and generate private key
AUTH_APPLE_ID=your.apple.services.id
AUTH_APPLE_SECRET=-----BEGIN EC PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END EC PRIVATE KEY-----

# Apple Team ID (10 characters)
AUTH_APPLE_TEAM_ID=YOURTEAMID

# Apple Key ID
AUTH_APPLE_KEY_ID=YOURKEYID

# =============================================================================
# STRIPE PAYMENTS (Required for payment processing)
# =============================================================================
# Get from: https://dashboard.stripe.com/apikeys
# Use test keys (sk_test_, pk_test_) for development
# Use live keys (sk_live_, pk_live_) for production

# Secret key - NEVER expose this in client-side code
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Publishable key (also needed in mobile app)
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Webhook secret for verifying Stripe webhook signatures
# Get from: https://dashboard.stripe.com/webhooks > Your webhook > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Connect - Platform settings
# Your platform account ID (starts with 'acct_')
STRIPE_PLATFORM_ACCOUNT_ID=acct_your_platform_account_id

# Application fee percentage (e.g., 15 for 15%)
STRIPE_APPLICATION_FEE_PERCENT=15

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================
# Base URL for your application
# Development: http://localhost:3000
# Production: https://yourdomain.com
APP_URL=http://localhost:3000

# Environment mode
NODE_ENV=development

# =============================================================================
# OPTIONAL: ADVANCED CONFIGURATION
# =============================================================================

# Convex site URL (usually auto-detected)
# CONVEX_SITE_URL=https://your-deployment.convex.site

# Logging level (debug, info, warn, error)
LOG_LEVEL=debug

# JWT token expiration (in seconds)
AUTH_SESSION_EXPIRY=2592000

# =============================================================================
# DEVELOPMENT HELPERS
# =============================================================================
# Skip email sending in development (logs to console instead)
DEV_SKIP_EMAIL=true

# Use mock payment intents in development (no real charges)
DEV_MOCK_PAYMENTS=true

# Enable verbose Convex query logging
CONVEX_VERBOSE_LOGS=true
