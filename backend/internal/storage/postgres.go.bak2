func (p *PostgresStorage) CreateReview(ctx context.Context, review *models.Review) error {
	query := `
		INSERT INTO reviews (
			id, appointment_id, client_id, barber_id, rating, comment, photos, created_at
		) VALUES ($1, $2, $3, $4, $5, $6, $7, $8)
	`

	review.CreatedAt = time.Now()

	var comment sql.NullString
	if review.Comment != nil {
		comment = sql.NullString{String: *review.Comment, Valid: true}
	}

	var photosJSON []byte
	if len(review.Photos) > 0 {
		photosJSON, _ = json.Marshal(review.Photos)
	}

	_, err := p.pool.Exec(ctx, query,
		review.ID, review.AppointmentID, review.ClientID, review.BarberID,
		review.Rating, comment, photosJSON, review.CreatedAt,
	)

	if err != nil {
		return fmt.Errorf("failed to create review: %w", err)
	}

	return nil
}

func (p *PostgresStorage) UpdateReview(ctx context.Context, review *models.Review) error {
	query := `
		UPDATE reviews SET
			rating = $2, comment = $3, photos = $4
		WHERE id = $1
	`

	var comment sql.NullString
	if review.Comment != nil {
		comment = sql.NullString{String: *review.Comment, Valid: true}
	}

	var photosJSON []byte
	if len(review.Photos) > 0 {
		photosJSON, _ = json.Marshal(review.Photos)
	}

	result, err := p.pool.Exec(ctx, query,
		review.ID, review.Rating, comment, photosJSON,
	)

	if err != nil {
		return fmt.Errorf("failed to update review: %w", err)
	}

	if result.RowsAffected() == 0 {
		return ErrReviewNotFound
	}

	return nil
}

