		)
		if err != nil {
			return nil, fmt.Errorf("failed to scan product: %w", err)
		}

		// Handle nullable fields
		if barberID.Valid {
			id := uuid.MustParse(barberID.String)
			product.BarberID = &id
		}

		// Parse JSON fields
		if len(imagesJSON) > 0 {
			json.Unmarshal(imagesJSON, &product.Images)
		}
		if len(specsJSON) > 0 {
			json.Unmarshal(specsJSON, &product.Specs)
		}

		products = append(products, &product)
	}

	return products, rows.Err()
}

func (p *PostgresStorage) GetProductsByBarberID(ctx context.Context, barberID uuid.UUID) ([]*models.Product, error) {
	query := `
