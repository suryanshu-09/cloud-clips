func (p *PostgresStorage) GetOrder(ctx context.Context, id uuid.UUID) (*models.Order, error) {
	query := `
		SELECT id, user_id, status, items, total_amount, shipping_address, 
		       payment_id, created_at, updated_at
		FROM orders WHERE id = $1
	`

	var order models.Order
	var itemsJSON, addressJSON []byte
	var paymentID sql.NullString

	err := p.pool.QueryRow(ctx, query, id).Scan(
		&order.ID, &order.UserID, &order.Status, &itemsJSON, &order.TotalAmount,
		&addressJSON, &paymentID, &order.CreatedAt, &order.UpdatedAt,
	)

	if err == pgx.ErrNoRows {
		return nil, ErrOrderNotFound
	}
	if err != nil {
		return nil, fmt.Errorf("failed to get order: %w", err)
	}

	// Handle nullable fields
	if paymentID.Valid {
		order.PaymentID = &paymentID.String
	}

	// Parse JSON fields
	if len(itemsJSON) > 0 {
		json.Unmarshal(itemsJSON, &order.Items)
	}
	if len(addressJSON) > 0 {
		json.Unmarshal(addressJSON, &order.ShippingAddress)
	}

	return &order, nil
}

func (p *PostgresStorage) GetOrders(ctx context.Context) ([]*models.Order, error) {
