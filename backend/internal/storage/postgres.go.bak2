func (p *PostgresStorage) CreateAppointment(ctx context.Context, appointment *models.Appointment) error {
	query := `
		INSERT INTO appointments (
			id, client_id, barber_id, status, service_type, hair_type,
			special_requests, location_type, location_address, location_coordinates,
			scheduled_for, duration, price, applied_coupon_id,
			payment_status, payment_id, created_at, updated_at
		) VALUES ($1, $2, $3, $4, $5, $6, $7, $8, $9, ST_SetSRID(ST_MakePoint($10, $11), 4326), $12, $13, $14, $15, $16, $17, $18, $19)
	`

	now := time.Now()
	appointment.CreatedAt = now
	appointment.UpdatedAt = now

	var hairType sql.NullString
	if appointment.HairType != "" {
		hairType = sql.NullString{String: string(appointment.HairType), Valid: true}
	}

	var specialRequests sql.NullString
	if appointment.SpecialRequests != nil {
		specialRequests = sql.NullString{String: *appointment.SpecialRequests, Valid: true}
	}

	var locationType sql.NullString
	if appointment.Location.Type != "" {
		locationType = sql.NullString{String: string(appointment.Location.Type), Valid: true}
	}

	var locationAddress sql.NullString
	if appointment.Location.Address != nil {
		locationAddress = sql.NullString{String: *appointment.Location.Address, Valid: true}
	}

	var lng, lat float64
	if len(appointment.Location.Coordinates) >= 2 {
		lng = appointment.Location.Coordinates[0]
		lat = appointment.Location.Coordinates[1]
	}

	var appliedCouponID sql.NullString
	if appointment.AppliedCouponID != nil {
		appliedCouponID = sql.NullString{String: appointment.AppliedCouponID.String(), Valid: true}
	}

	var paymentID sql.NullString
	if appointment.PaymentID != nil {
		paymentID = sql.NullString{String: *appointment.PaymentID, Valid: true}
	}

	_, err := p.pool.Exec(ctx, query,
		appointment.ID, appointment.ClientID, appointment.BarberID, appointment.Status,
		appointment.ServiceType, hairType, specialRequests, locationType,
		locationAddress, lng, lat, appointment.ScheduledFor, appointment.Duration,
		appointment.Price, appliedCouponID, appointment.PaymentStatus, paymentID,
		appointment.CreatedAt, appointment.UpdatedAt,
	)

	if err != nil {
		return fmt.Errorf("failed to create appointment: %w", err)
	}

	return nil
}

func (p *PostgresStorage) UpdateAppointment(ctx context.Context, appointment *models.Appointment) error {
	query := `
		UPDATE appointments SET
			status = $2, service_type = $3, hair_type = $4,
			special_requests = $5, location_type = $6, location_address = $7,
			location_coordinates = ST_SetSRID(ST_MakePoint($8, $9), 4326),
			scheduled_for = $10, duration = $11, price = $12,
			applied_coupon_id = $13, payment_status = $14, payment_id = $15,
			updated_at = $16
		WHERE id = $1
	`

	appointment.UpdatedAt = time.Now()

	var hairType sql.NullString
	if appointment.HairType != "" {
		hairType = sql.NullString{String: string(appointment.HairType), Valid: true}
	}

	var specialRequests sql.NullString
	if appointment.SpecialRequests != nil {
		specialRequests = sql.NullString{String: *appointment.SpecialRequests, Valid: true}
	}

	var locationType sql.NullString
	if appointment.Location.Type != "" {
		locationType = sql.NullString{String: string(appointment.Location.Type), Valid: true}
	}

	var locationAddress sql.NullString
	if appointment.Location.Address != nil {
		locationAddress = sql.NullString{String: *appointment.Location.Address, Valid: true}
	}

	var lng, lat float64
	if len(appointment.Location.Coordinates) >= 2 {
		lng = appointment.Location.Coordinates[0]
		lat = appointment.Location.Coordinates[1]
	}

	var appliedCouponID sql.NullString
	if appointment.AppliedCouponID != nil {
		appliedCouponID = sql.NullString{String: appointment.AppliedCouponID.String(), Valid: true}
	}

	var paymentID sql.NullString
	if appointment.PaymentID != nil {
		paymentID = sql.NullString{String: *appointment.PaymentID, Valid: true}
	}

	result, err := p.pool.Exec(ctx, query,
		appointment.ID, appointment.Status, appointment.ServiceType, hairType,
		specialRequests, locationType, locationAddress, lng, lat,
		appointment.ScheduledFor, appointment.Duration, appointment.Price,
		appliedCouponID, appointment.PaymentStatus, paymentID, appointment.UpdatedAt,
	)

	if err != nil {
		return fmt.Errorf("failed to update appointment: %w", err)
	}

	if result.RowsAffected() == 0 {
		return ErrAppointmentNotFound
	}

	return nil
}

func (p *PostgresStorage) DeleteAppointment(ctx context.Context, id uuid.UUID) error {
	query := `DELETE FROM appointments WHERE id = $1`

	result, err := p.pool.Exec(ctx, query, id)
	if err != nil {
		return fmt.Errorf("failed to delete appointment: %w", err)
	}

	if result.RowsAffected() == 0 {
		return ErrAppointmentNotFound
	}

	return nil
}

