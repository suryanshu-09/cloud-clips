func (p *PostgresStorage) GetChatMessage(ctx context.Context, id uuid.UUID) (*models.ChatMessage, error) {
	query := `
		SELECT id, appointment_id, sender_id, receiver_id, content, created_at, read_at
		FROM chat_messages WHERE id = $1
	`

	var msg models.ChatMessage
	var readAt sql.NullTime

	err := p.pool.QueryRow(ctx, query, id).Scan(
		&msg.ID, &msg.AppointmentID, &msg.SenderID, &msg.ReceiverID,
		&msg.Content, &msg.CreatedAt, &readAt,
	)

	if err == pgx.ErrNoRows {
		return nil, ErrChatMessageNotFound
	}
	if err != nil {
		return nil, fmt.Errorf("failed to get chat message: %w", err)
	}

	// Handle nullable fields
	if readAt.Valid {
		msg.ReadAt = &readAt.Time
	}

	return &msg, nil
}

