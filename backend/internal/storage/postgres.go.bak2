func (p *PostgresStorage) GetChatThreads(ctx context.Context, userID uuid.UUID) ([]uuid.UUID, error) {
	query := `
		SELECT DISTINCT appointment_id
		FROM chat_messages
		WHERE sender_id = $1 OR receiver_id = $1
		ORDER BY appointment_id
	`

	rows, err := p.pool.Query(ctx, query, userID)
	if err != nil {
		return nil, fmt.Errorf("failed to get chat threads: %w", err)
	}
	defer rows.Close()

	var threads []uuid.UUID
	for rows.Next() {
		var appointmentID uuid.UUID
		err := rows.Scan(&appointmentID)
		if err != nil {
			return nil, fmt.Errorf("failed to scan thread: %w", err)
		}
		threads = append(threads, appointmentID)
	}

	return threads, rows.Err()
}

func (p *PostgresStorage) GetUnreadMessageCount(ctx context.Context, userID uuid.UUID) (int, error) {
	query := `
		SELECT COUNT(*)
		FROM chat_messages
		WHERE receiver_id = $1 AND read_at IS NULL
	`

	var count int
	err := p.pool.QueryRow(ctx, query, userID).Scan(&count)
	if err != nil {
		return 0, fmt.Errorf("failed to get unread message count: %w", err)
	}

	return count, nil
}

func (p *PostgresStorage) CreateChatMessage(ctx context.Context, message *models.ChatMessage) error {
	query := `
		INSERT INTO chat_messages (
			id, appointment_id, sender_id, receiver_id, content, created_at, read_at
		) VALUES ($1, $2, $3, $4, $5, $6, $7)
	`

	message.CreatedAt = time.Now()

	var readAt sql.NullTime
	if message.ReadAt != nil {
		readAt = sql.NullTime{Time: *message.ReadAt, Valid: true}
	}

	_, err := p.pool.Exec(ctx, query,
		message.ID, message.AppointmentID, message.SenderID, message.ReceiverID,
		message.Content, message.CreatedAt, readAt,
	)

	if err != nil {
		return fmt.Errorf("failed to create chat message: %w", err)
	}

	return nil
}

func (p *PostgresStorage) UpdateChatMessage(ctx context.Context, message *models.ChatMessage) error {
	query := `
		UPDATE chat_messages SET
			content = $2, read_at = $3
		WHERE id = $1
	`

	var readAt sql.NullTime
	if message.ReadAt != nil {
		readAt = sql.NullTime{Time: *message.ReadAt, Valid: true}
	}

	result, err := p.pool.Exec(ctx, query,
		message.ID, message.Content, readAt,
	)

	if err != nil {
		return fmt.Errorf("failed to update chat message: %w", err)
	}

	if result.RowsAffected() == 0 {
		return ErrChatMessageNotFound
	}

	return nil
}

func (p *PostgresStorage) MarkMessagesAsRead(ctx context.Context, userID uuid.UUID, appointmentID uuid.UUID) error {
	query := `
		UPDATE chat_messages SET read_at = NOW()
		WHERE receiver_id = $1 AND appointment_id = $2 AND read_at IS NULL
	`

	_, err := p.pool.Exec(ctx, query, userID, appointmentID)
	if err != nil {
		return fmt.Errorf("failed to mark messages as read: %w", err)
	}

	return nil
}

func (p *PostgresStorage) DeleteChatMessage(ctx context.Context, id uuid.UUID) error {
	query := `DELETE FROM chat_messages WHERE id = $1`

	result, err := p.pool.Exec(ctx, query, id)
	if err != nil {
		return fmt.Errorf("failed to delete chat message: %w", err)
	}

	if result.RowsAffected() == 0 {
		return ErrChatMessageNotFound
	}

	return nil
}

// ============================================================================
// Notification Operations
// ============================================================================

func (p *PostgresStorage) GetNotification(ctx context.Context, id uuid.UUID) (*models.Notification, error) {
	query := `
		SELECT id, user_id, type, title, body, data, is_read, created_at
		FROM notifications WHERE id = $1
	`

	var notif models.Notification
	var dataJSON []byte

	err := p.pool.QueryRow(ctx, query, id).Scan(
		&notif.ID, &notif.UserID, &notif.Type, &notif.Title,
		&notif.Body, &dataJSON, &notif.IsRead, &notif.CreatedAt,
	)

	if err == pgx.ErrNoRows {
		return nil, ErrNotificationNotFound
	}
	if err != nil {
		return nil, fmt.Errorf("failed to get notification: %w", err)
	}

	// Parse JSON fields
	if len(dataJSON) > 0 {
		json.Unmarshal(dataJSON, &notif.Data)
	}

	return &notif, nil
}

func (p *PostgresStorage) GetNotifications(ctx context.Context) ([]*models.Notification, error) {
	query := `
		SELECT id, user_id, type, title, body, data, is_read, created_at
		FROM notifications
		ORDER BY created_at DESC
	`

	rows, err := p.pool.Query(ctx, query)
	if err != nil {
		return nil, fmt.Errorf("failed to get notifications: %w", err)
	}
	defer rows.Close()

	var notifications []*models.Notification
	for rows.Next() {
		var notif models.Notification
		var dataJSON []byte

		err := rows.Scan(
			&notif.ID, &notif.UserID, &notif.Type, &notif.Title,
			&notif.Body, &dataJSON, &notif.IsRead, &notif.CreatedAt,
		)
		if err != nil {
			return nil, fmt.Errorf("failed to scan notification: %w", err)
		}

		// Parse JSON fields
		if len(dataJSON) > 0 {
			json.Unmarshal(dataJSON, &notif.Data)
		}

		notifications = append(notifications, &notif)
	}

	return notifications, rows.Err()
}

func (p *PostgresStorage) GetUserNotifications(ctx context.Context, userID uuid.UUID) ([]*models.Notification, error) {
	query := `
		SELECT id, user_id, type, title, body, data, is_read, created_at
		FROM notifications
		WHERE user_id = $1
		ORDER BY created_at DESC
	`

	rows, err := p.pool.Query(ctx, query, userID)
	if err != nil {
		return nil, fmt.Errorf("failed to get user notifications: %w", err)
	}
	defer rows.Close()

	var notifications []*models.Notification
	for rows.Next() {
		var notif models.Notification
		var dataJSON []byte

		err := rows.Scan(
			&notif.ID, &notif.UserID, &notif.Type, &notif.Title,
			&notif.Body, &dataJSON, &notif.IsRead, &notif.CreatedAt,
		)
		if err != nil {
			return nil, fmt.Errorf("failed to scan notification: %w", err)
		}

		// Parse JSON fields
		if len(dataJSON) > 0 {
			json.Unmarshal(dataJSON, &notif.Data)
		}

		notifications = append(notifications, &notif)
	}

	return notifications, rows.Err()
}

func (p *PostgresStorage) GetUnreadNotificationCount(ctx context.Context, userID uuid.UUID) (int, error) {
	query := `
		SELECT COUNT(*)
		FROM notifications
		WHERE user_id = $1 AND is_read = false
	`

	var count int
	err := p.pool.QueryRow(ctx, query, userID).Scan(&count)
	if err != nil {
		return 0, fmt.Errorf("failed to get unread notification count: %w", err)
	}

	return count, nil
}

func (p *PostgresStorage) CreateNotification(ctx context.Context, notification *models.Notification) error {
	query := `
		INSERT INTO notifications (
			id, user_id, type, title, body, data, is_read, created_at
		) VALUES ($1, $2, $3, $4, $5, $6, $7, $8)
	`

	notification.CreatedAt = time.Now()

	var dataJSON []byte
	if len(notification.Data) > 0 {
		dataJSON, _ = json.Marshal(notification.Data)
	}

	_, err := p.pool.Exec(ctx, query,
		notification.ID, notification.UserID, notification.Type, notification.Title,
		notification.Body, dataJSON, notification.IsRead, notification.CreatedAt,
	)

	if err != nil {
		return fmt.Errorf("failed to create notification: %w", err)
	}

	return nil
}

func (p *PostgresStorage) UpdateNotification(ctx context.Context, notification *models.Notification) error {
	query := `
		UPDATE notifications SET
			type = $2, title = $3, body = $4, data = $5, is_read = $6
		WHERE id = $1
	`

	var dataJSON []byte
	if len(notification.Data) > 0 {
		dataJSON, _ = json.Marshal(notification.Data)
	}

	result, err := p.pool.Exec(ctx, query,
		notification.ID, notification.Type, notification.Title,
		notification.Body, dataJSON, notification.IsRead,
	)

	if err != nil {
		return fmt.Errorf("failed to update notification: %w", err)
	}

	if result.RowsAffected() == 0 {
		return ErrNotificationNotFound
	}

	return nil
}

func (p *PostgresStorage) MarkNotificationAsRead(ctx context.Context, id uuid.UUID) error {
	query := `UPDATE notifications SET is_read = true WHERE id = $1`

	result, err := p.pool.Exec(ctx, query, id)
	if err != nil {
		return fmt.Errorf("failed to mark notification as read: %w", err)
	}

	if result.RowsAffected() == 0 {
		return ErrNotificationNotFound
	}

	return nil
}

func (p *PostgresStorage) MarkAllNotificationsAsRead(ctx context.Context, userID uuid.UUID) error {
	query := `UPDATE notifications SET is_read = true WHERE user_id = $1 AND is_read = false`

	_, err := p.pool.Exec(ctx, query, userID)
	if err != nil {
		return fmt.Errorf("failed to mark all notifications as read: %w", err)
	}

	return nil
}

func (p *PostgresStorage) DeleteNotification(ctx context.Context, id uuid.UUID) error {
	query := `DELETE FROM notifications WHERE id = $1`

	result, err := p.pool.Exec(ctx, query, id)
	if err != nil {
		return fmt.Errorf("failed to delete notification: %w", err)
	}

	if result.RowsAffected() == 0 {
		return ErrNotificationNotFound
	}

	return nil
}
