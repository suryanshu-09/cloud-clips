func (p *PostgresStorage) CreateOrder(ctx context.Context, order *models.Order) error {
	query := `
		INSERT INTO orders (
			id, user_id, status, items, total_amount, shipping_address, 
			payment_id, created_at, updated_at
		) VALUES ($1, $2, $3, $4, $5, $6, $7, $8, $9)
	`

	now := time.Now()
	order.CreatedAt = now
	order.UpdatedAt = now

	var itemsJSON, addressJSON []byte
	if len(order.Items) > 0 {
		itemsJSON, _ = json.Marshal(order.Items)
	}
	addressJSON, _ = json.Marshal(order.ShippingAddress)

	var paymentID sql.NullString
	if order.PaymentID != nil {
		paymentID = sql.NullString{String: *order.PaymentID, Valid: true}
	}

	_, err := p.pool.Exec(ctx, query,
		order.ID, order.UserID, order.Status, itemsJSON, order.TotalAmount,
		addressJSON, paymentID, order.CreatedAt, order.UpdatedAt,
	)

	if err != nil {
		return fmt.Errorf("failed to create order: %w", err)
	}

	return nil
}

func (p *PostgresStorage) UpdateOrder(ctx context.Context, order *models.Order) error {
	query := `
		UPDATE orders SET
			status = $2, items = $3, total_amount = $4, shipping_address = $5,
			payment_id = $6, updated_at = $7
		WHERE id = $1
	`

	order.UpdatedAt = time.Now()

	var itemsJSON, addressJSON []byte
	if len(order.Items) > 0 {
		itemsJSON, _ = json.Marshal(order.Items)
	}
	addressJSON, _ = json.Marshal(order.ShippingAddress)

	var paymentID sql.NullString
	if order.PaymentID != nil {
		paymentID = sql.NullString{String: *order.PaymentID, Valid: true}
	}

	result, err := p.pool.Exec(ctx, query,
		order.ID, order.Status, itemsJSON, order.TotalAmount,
		addressJSON, paymentID, order.UpdatedAt,
	)

	if err != nil {
		return fmt.Errorf("failed to update order: %w", err)
	}

	if result.RowsAffected() == 0 {
		return ErrOrderNotFound
	}

	return nil
}

func (p *PostgresStorage) DeleteOrder(ctx context.Context, id uuid.UUID) error {
	query := `DELETE FROM orders WHERE id = $1`

	result, err := p.pool.Exec(ctx, query, id)
	if err != nil {
		return fmt.Errorf("failed to delete order: %w", err)
	}

	if result.RowsAffected() == 0 {
		return ErrOrderNotFound
	}

	return nil
}

