	if coupon.UsageLimit != nil {
		usageLimit = sql.NullInt32{Int32: int32(*coupon.UsageLimit), Valid: true}
	}

	var applicableToJSON []byte
	applicableToJSON, _ = json.Marshal(coupon.ApplicableTo)

	result, err := p.pool.Exec(ctx, query,
		coupon.ID, coupon.Code, coupon.Type, coupon.Value, minAmount, maxDiscount,
		coupon.ValidFrom, coupon.ValidUntil, usageLimit, coupon.UsageCount, applicableToJSON,
	)

	if err != nil {
		return fmt.Errorf("failed to update coupon: %w", err)
	}

	if result.RowsAffected() == 0 {
		return ErrCouponNotFound
	}

	return nil
}

func (p *PostgresStorage) DeleteCoupon(ctx context.Context, id uuid.UUID) error {
	query := `DELETE FROM coupons WHERE id = $1`

