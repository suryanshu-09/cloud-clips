func (p *PostgresStorage) GetProduct(ctx context.Context, id uuid.UUID) (*models.Product, error) {
	query := `
		SELECT id, name, description, category, price, images, stock, rating, 
		       total_reviews, barber_id, specs
		FROM products WHERE id = $1
	`

	var product models.Product
	var imagesJSON, specsJSON []byte
	var barberID sql.NullString

	err := p.pool.QueryRow(ctx, query, id).Scan(
		&product.ID, &product.Name, &product.Description, &product.Category,
		&product.Price, &imagesJSON, &product.Stock, &product.Rating,
		&product.TotalReviews, &barberID, &specsJSON,
	)

	if err == pgx.ErrNoRows {
		return nil, ErrProductNotFound
	}
	if err != nil {
		return nil, fmt.Errorf("failed to get product: %w", err)
	}

	// Handle nullable fields
	if barberID.Valid {
		id := uuid.MustParse(barberID.String)
		product.BarberID = &id
	}

	// Parse JSON fields
	if len(imagesJSON) > 0 {
		json.Unmarshal(imagesJSON, &product.Images)
	}
	if len(specsJSON) > 0 {
		json.Unmarshal(specsJSON, &product.Specs)
	}

	return &product, nil
}

