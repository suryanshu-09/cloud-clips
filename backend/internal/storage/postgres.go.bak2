func (p *PostgresStorage) GetReview(ctx context.Context, id uuid.UUID) (*models.Review, error) {
	query := `
		SELECT id, appointment_id, client_id, barber_id, rating, comment, photos, created_at
		FROM reviews WHERE id = $1
	`

	var review models.Review
	var comment sql.NullString
	var photosJSON []byte

	err := p.pool.QueryRow(ctx, query, id).Scan(
		&review.ID, &review.AppointmentID, &review.ClientID, &review.BarberID,
		&review.Rating, &comment, &photosJSON, &review.CreatedAt,
	)

	if err == pgx.ErrNoRows {
		return nil, ErrReviewNotFound
	}
	if err != nil {
		return nil, fmt.Errorf("failed to get review: %w", err)
	}

	// Handle nullable fields
	if comment.Valid {
		review.Comment = &comment.String
	}
	if len(photosJSON) > 0 {
		json.Unmarshal(photosJSON, &review.Photos)
	}

	return &review, nil
}

