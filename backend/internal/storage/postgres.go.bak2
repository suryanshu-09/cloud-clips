func (p *PostgresStorage) GetCoupon(ctx context.Context, id uuid.UUID) (*models.Coupon, error) {
	query := `
		SELECT id, code, type, value, min_amount, max_discount, valid_from, 
		       valid_until, usage_limit, usage_count, applicable_to
		FROM coupons WHERE id = $1
	`

	var coupon models.Coupon
	var minAmount, maxDiscount sql.NullFloat64
	var usageLimit sql.NullInt32
	var applicableToJSON []byte

	err := p.pool.QueryRow(ctx, query, id).Scan(
		&coupon.ID, &coupon.Code, &coupon.Type, &coupon.Value, &minAmount, &maxDiscount,
		&coupon.ValidFrom, &coupon.ValidUntil, &usageLimit, &coupon.UsageCount, &applicableToJSON,
	)

	if err == pgx.ErrNoRows {
		return nil, ErrCouponNotFound
	}
	if err != nil {
		return nil, fmt.Errorf("failed to get coupon: %w", err)
	}

	// Handle nullable fields
	if minAmount.Valid {
		val := minAmount.Float64
		coupon.MinAmount = &val
	}
	if maxDiscount.Valid {
		val := maxDiscount.Float64
		coupon.MaxDiscount = &val
	}
	if usageLimit.Valid {
		val := int(usageLimit.Int32)
		coupon.UsageLimit = &val
	}

	// Parse JSON fields
	if len(applicableToJSON) > 0 {
		json.Unmarshal(applicableToJSON, &coupon.ApplicableTo)
	}

	return &coupon, nil
}

